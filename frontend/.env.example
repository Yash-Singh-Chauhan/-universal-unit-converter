# Universal Unit Converter - Environment Configuration
# Copy this file to .env and fill in the values for local development.
# For Vercel deployment, set these in the Vercel Dashboard → Environment Variables.

# Backend API URL
# For local development with the backend running on port 3001, leave as default "/api"
# which proxies through Vite's dev server.
# For production (e.g., backend deployed on Render), set the full URL:
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
VITE_API_BASE_URL=/api
